{
    "multipart": [
        {
            "apply": { "model": "meeptech:block/pipe_center" }
        },
        {
            "when": { "south": "pipe" },
            "apply": { "model": "meeptech:block/pipe_arm", "x": 0, "y": 0 }
        },
        {
            "when": { "north": "pipe" },
            "apply": { "model": "meeptech:block/pipe_arm", "x": 0, "y": 180 }
        },
        {
            "when": { "east": "pipe" },
            "apply": { "model": "meeptech:block/pipe_arm", "x": 0, "y": 270 }
        },
        {
            "when": { "west": "pipe" },
            "apply": { "model": "meeptech:block/pipe_arm", "x": 0, "y": 90 }
        },
        {
            "when": { "up": "pipe" },
            "apply": { "model": "meeptech:block/pipe_arm", "x": 90, "y": 0 }
        },
        {
            "when": { "down": "pipe" },
            "apply": { "model": "meeptech:block/pipe_arm", "x": 270, "y": 0 }
