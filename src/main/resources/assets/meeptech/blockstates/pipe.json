        {
            "when": { "west": "inserter" },
            "apply": { "model": "meeptech:block/pipe_arm_inserter", "x": 0, "y": 90 }
        },
        {
            "when": { "up": "inserter" },
            "apply": { "model": "meeptech:block/pipe_arm_inserter", "x": 90, "y": 0 }
        },
        {
            "when": { "down": "inserter" },
            "apply": { "model": "meeptech:block/pipe_arm_inserter", "x": 270, "y": 0 }
